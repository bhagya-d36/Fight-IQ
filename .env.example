# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Optional overrides — defaults live in config.py. Uncomment to change.
# CHAT_MODEL=gemini-2.5-flash
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIM=768
# TOP_K=4
# MIN_SIMILARITY=0.35
# MAX_CHUNK_CHARS=1500
# GEMINI_TIMEOUT_MS=60000
# GEMINI_RETRY_ATTEMPTS=4

# Set to 1 if the first API call hangs ~20 seconds (network advertises IPv6
# but doesn't route it). See net_fix.py.
# FORCE_IPV4=1
