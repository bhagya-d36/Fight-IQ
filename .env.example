# Pick a chat LLM provider, then set that provider's API key below.
LLM_PROVIDER=gemini
# LLM_PROVIDER=openai
# LLM_PROVIDER=anthropic
# LLM_PROVIDER=deepseek
# LLM_PROVIDER=kimi

# Gemini — free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here
# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-key-here
# Anthropic (Claude) — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your-key-here
# DeepSeek — https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=your-key-here
# Kimi (Moonshot AI) — https://platform.moonshot.ai/console/api-keys
# MOONSHOT_API_KEY=your-key-here

# Optional overrides — defaults live in config.py. Uncomment to change.
# CHAT_MODEL=                     # blank = the chosen provider's default model
# EMBEDDING_MODEL=all-MiniLM-L6-v2  # local sentence-transformers model, no key needed
# TOP_K=4
# MIN_SIMILARITY=0.35
# MAX_CHUNK_CHARS=1500
# LLM_TIMEOUT_MS=60000
# LLM_RETRY_ATTEMPTS=4
# MAX_OUTPUT_TOKENS=1024
# MAX_SESSIONS=20
# SESSION_TTL_MINUTES=60
# MAX_CHAT_TURNS=20
# ENABLE_QUERY_REWRITE=true
# REWRITE_HISTORY_TURNS=3
# MAX_CHUNK_OVERLAP=200
# HYBRID_SEARCH=true
# RRF_K=60
# MAX_QUESTION_CHARS=1000
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=30
# RATE_LIMIT_WINDOW_SECONDS=60

# Set to 1 if the first API call hangs ~20 seconds (network advertises IPv6
# but doesn't route it). See net_fix.py.
# FORCE_IPV4=1
